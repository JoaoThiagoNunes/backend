# ====================
# BANCO DE DADOS
# ====================
DB_USER=postgres
DB_PASS=123456
DB_HOST=localhost
DB_PORT=5432
DB_NAME=profin_db

# ====================
# AUTENTICAÇÃO
# ====================
# IMPORTANTE: Altere estas senhas em produção!
SECRET_KEY=profin-secret-key-change-in-production-2024
ADMIN_PASSWORD=profin2024

# ====================
# CORS
# ====================
# Múltiplas origens separadas por vírgula
# Exemplo: http://localhost:3000,http://localhost:3001
CORS_ORIGINS=http://localhost:3000

# ====================
# LOGGING
# ====================
# Níveis: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ====================
# SCHEDULER
# ====================
# Timezone para tarefas agendadas
SCHEDULER_TIMEZONE=America/Maceio

# ====================
# ARQUIVOS
# ====================
# Tamanho máximo de upload em MB
MAX_UPLOAD_SIZE_MB=50



